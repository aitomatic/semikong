# Module Metadata
semicont-07-wfe-oxidation-systems: a owl:Ontology ;
    rdfs:label "Oxidation Systems Ontology" ;
    rdfs:comment "Industry-general concepts for thermal oxidation equipment and processes" ;
    owl:versionInfo "0.1.0" ;
    owl:imports <https://semicont.org/ontology/00-shared> ;
