# Thermal Processing Process Types
semicont-07-wfe-thermal-processing:ThermalProcessingProcess a owl:Class ;
    rdfs:label "Thermal Processing Process" ;
    rdfs:comment "Rapid thermal processing or annealing process" ;
    rdfs:subClassOf semicont-shared:ProcessStep ;
    rdfs:isDefinedBy semicont-07-wfe-thermal-processing: ;
    dc:source "Public domain semiconductor process knowledge" ;
    dc:rights "Fair use: industry-general thermal processing concepts" ;
    prov:wasInformedBy "Model synthesis of rapid thermal processes" ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-build> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

# Process Parameters
semicont-07-wfe-thermal-processing:hasPeakTemperature a owl:DatatypeProperty ;
    rdfs:label "has peak temperature" ;
    rdfs:comment "Peak processing temperature in Celsius" ;
    rdfs:domain semicont-07-wfe-thermal-processing:ThermalProcessingProcess ;
    rdfs:range xsd:integer ;
    rdfs:isDefinedBy semicont-07-wfe-thermal-processing: ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-build> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-07-wfe-thermal-processing:hasRampRate a owl:DatatypeProperty ;
    rdfs:label "has ramp rate" ;
    rdfs:comment "Temperature ramp rate in °C/second" ;
    rdfs:domain semicont-07-wfe-thermal-processing:ThermalProcessingProcess ;
    rdfs:range xsd:decimal ;
    rdfs:isDefinedBy semicont-07-wfe-thermal-processing: ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-build> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-07-wfe-thermal-processing:hasProcessTime a owl:DatatypeProperty ;
    rdfs:label "has process time" ;
    rdfs:comment "Time at peak temperature in seconds" ;
    rdfs:domain semicont-07-wfe-thermal-processing:ThermalProcessingProcess ;
    rdfs:range xsd:integer ;
    rdfs:isDefinedBy semicont-07-wfe-thermal-processing: ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-build> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-07-wfe-thermal-processing:hasAmbientGas a owl:DatatypeProperty ;
    rdfs:label "has ambient gas" ;
    rdfs:comment "Process ambient gas (e.g., nitrogen, argon)" ;
    rdfs:domain semicont-07-wfe-thermal-processing:ThermalProcessingProcess ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy semicont-07-wfe-thermal-processing: ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-build> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

