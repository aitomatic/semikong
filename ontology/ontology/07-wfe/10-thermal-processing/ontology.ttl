# Thermal Processing Ontology
# Industry-general concepts for rapid thermal processing and annealing equipment

@prefix semicont-07-wfe-thermal-processing: <https://semicont.org/ontology/07-wfe/10-thermal-processing#> .
@prefix semicont-shared: <https://semicont.org/ontology/00-shared#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .

# Module Metadata
semicont-07-wfe-thermal-processing: a owl:Ontology ;
    rdfs:label "Thermal Processing Ontology" ;
    rdfs:comment "Industry-general concepts for rapid thermal processing and annealing equipment" ;
    owl:versionInfo "0.1.0" ;
    owl:imports <https://semicont.org/ontology/00-shared> ;
    dc:source "Public semiconductor engineering literature and industry-standard thermal processing classifications" ;
    dc:rights "Fair use: industry-general thermal processing concepts" ;
    prov:wasInformedBy "Model synthesis of public domain semiconductor thermal processing knowledge" ;
    prov:hadPrimarySource <https://en.wikipedia.org/wiki/Rapid_thermal_processing> ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-build> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

# Thermal Processing Equipment
semicont-07-wfe-thermal-processing:ThermalProcessingEquipment a owl:Class ;
    rdfs:label "Thermal Processing Equipment" ;
    rdfs:comment "Equipment for rapid thermal processing and annealing" ;
    rdfs:subClassOf semicont-shared:Equipment ;
    rdfs:isDefinedBy semicont-07-wfe-thermal-processing: ;
    dc:source "Public domain semiconductor equipment taxonomy" ;
    dc:rights "Fair use: generic thermal processing equipment concept" ;
    prov:wasInformedBy "Industry-standard rapid thermal processing classifications" ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-build> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

# Laser Annealing Systems
semicont-07-wfe-thermal-processing:LaserAnnealingSystem a owl:Class ;
    rdfs:label "Laser Annealing System" ;
    rdfs:comment "System for annealing using laser heating" ;
    rdfs:subClassOf semicont-07-wfe-thermal-processing:ThermalProcessingEquipment ;
    rdfs:isDefinedBy semicont-07-wfe-thermal-processing: ;
    dc:source "Public domain semiconductor thermal processing literature" ;
    dc:rights "Fair use: generic laser annealing concept" ;
    prov:wasInformedBy "Industry-standard laser thermal processing technologies" ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-build> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

# Rapid Thermal Annealing
semicont-07-wfe-thermal-processing:RapidThermalAnneal a owl:Class ;
    rdfs:label "Rapid Thermal Anneal" ;
    rdfs:comment "Rapid thermal annealing system" ;
    rdfs:subClassOf semicont-07-wfe-thermal-processing:ThermalProcessingEquipment ;
    rdfs:isDefinedBy semicont-07-wfe-thermal-processing: ;
