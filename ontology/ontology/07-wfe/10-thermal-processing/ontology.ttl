# Spike Annealing
semicont-07-wfe-thermal-processing:SpikeAnneal a owl:Class ;
    rdfs:label "Spike Anneal" ;
    rdfs:comment "Spike annealing system with rapid heating and cooling" ;
    rdfs:subClassOf semicont-07-wfe-thermal-processing:ThermalProcessingEquipment ;
    rdfs:isDefinedBy semicont-07-wfe-thermal-processing: ;
