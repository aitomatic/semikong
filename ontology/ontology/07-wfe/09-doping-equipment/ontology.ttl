# Process Parameters
semicont-07-wfe-doping-equipment:hasTemperature a owl:DatatypeProperty ;
    rdfs:label "has temperature" ;
    rdfs:comment "Process temperature in Celsius" ;
    rdfs:domain semicont-07-wfe-doping-equipment:ThermalDopingProcess ;
    rdfs:range xsd:integer ;
    rdfs:isDefinedBy semicont-07-wfe-doping-equipment: ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-build> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-07-wfe-doping-equipment:hasDuration a owl:DatatypeProperty ;
    rdfs:label "has duration" ;
    rdfs:comment "Process duration in minutes" ;
    rdfs:domain semicont-07-wfe-doping-equipment:ThermalDopingProcess ;
    rdfs:range xsd:integer ;
    rdfs:isDefinedBy semicont-07-wfe-doping-equipment: ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-build> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-07-wfe-doping-equipment:hasAmbientGas a owl:DatatypeProperty ;
    rdfs:label "has ambient gas" ;
