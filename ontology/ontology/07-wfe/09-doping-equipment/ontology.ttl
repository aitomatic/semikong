    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-07-wfe-doping-equipment:PredepositionProcess a owl:Class ;
    rdfs:label "Predeposition Process" ;
    rdfs:comment "First step in two-step diffusion doping" ;
    rdfs:subClassOf semicont-07-wfe-doping-equipment:ThermalDopingProcess ;
    rdfs:isDefinedBy semicont-07-wfe-doping-equipment: ;
