    rdfs:comment "Furnace for predeposition diffusion process" ;
    rdfs:subClassOf semicont-07-wfe-doping-equipment:DiffusionFurnace ;
    rdfs:isDefinedBy semicont-07-wfe-doping-equipment: ;
