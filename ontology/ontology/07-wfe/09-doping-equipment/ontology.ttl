# Doping Equipment Ontology
# Industry-general concepts for thermal diffusion doping equipment and processes

@prefix semicont-07-wfe-doping-equipment: <https://semicont.org/ontology/07-wfe/09-doping-equipment#> .
@prefix semicont-shared: <https://semicont.org/ontology/00-shared#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .

# Module Metadata
semicont-07-wfe-doping-equipment: a owl:Ontology ;
    rdfs:label "Doping Equipment Ontology" ;
    rdfs:comment "Industry-general concepts for thermal diffusion doping equipment and processes" ;
    owl:versionInfo "0.1.0" ;
    owl:imports <https://semicont.org/ontology/00-shared> ;
    dc:source "Public semiconductor engineering literature and industry-standard diffusion doping classifications" ;
    dc:rights "Fair use: industry-general thermal doping concepts" ;
    prov:wasInformedBy "Model synthesis of public domain semiconductor diffusion knowledge" ;
    prov:hadPrimarySource <https://en.wikipedia.org/wiki/Diffusion#Semiconductor_fabrication> ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-build> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

# Diffusion Furnaces
semicont-07-wfe-doping-equipment:DiffusionFurnace a owl:Class ;
