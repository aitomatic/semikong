# Ion Implantation Ontology
# Industry-general concepts for ion implantation equipment and processes

@prefix semicont-07-wfe-ion-implantation: <https://semicont.org/ontology/07-wfe/05-ion-implantation#> .
@prefix semicont-shared: <https://semicont.org/ontology/00-shared#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .

# Module Metadata
semicont-07-wfe-ion-implantation: a owl:Ontology ;
    rdfs:label "Ion Implantation Ontology" ;
    rdfs:comment "Industry-general concepts for ion implantation equipment and processes" ;
    owl:versionInfo "0.1.0" ;
    owl:imports <https://semicont.org/ontology/00-shared> ;
    dc:source "Public semiconductor engineering literature and industry-standard ion implantation classifications" ;
    dc:rights "Fair use: industry-general ion implantation concepts" ;
    prov:wasInformedBy "Model synthesis of public domain semiconductor doping knowledge" ;
    prov:hadPrimarySource <https://en.wikipedia.org/wiki/Ion_implantation> ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-build> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

# Ion Implantation Equipment
semicont-07-wfe-ion-implantation:IonImplantationEquipment a owl:Class ;
    rdfs:label "Ion Implantation Equipment" ;
    rdfs:comment "Equipment for implanting ions into semiconductor wafers" ;
    rdfs:subClassOf semicont-shared:Equipment ;
    rdfs:isDefinedBy semicont-07-wfe-ion-implantation: ;
    dc:source "Public domain semiconductor equipment taxonomy" ;
    dc:rights "Fair use: generic ion implantation equipment concept" ;
    prov:wasInformedBy "Industry-standard ion implantation equipment classifications" ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-build> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

