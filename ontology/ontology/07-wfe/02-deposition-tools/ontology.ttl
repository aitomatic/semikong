@prefix dc: <http://purl.org/dc/elements/1.1/> .

# Module Metadata
semicont-07-wfe-deposition-tools: a owl:Ontology ;
    rdfs:label "Deposition Tools Ontology" ;
    rdfs:comment "Industry-general concepts for thin film deposition equipment and processes" ;
    owl:versionInfo "0.1.0" ;
    owl:imports <https://semicont.org/ontology/00-shared> ;
    dc:source "Public semiconductor engineering literature and industry-standard deposition process classifications" ;
    dc:rights "Fair use: industry-general deposition concepts" ;
    prov:wasInformedBy "Model synthesis of public domain thin film deposition knowledge" ;
    prov:hadPrimarySource <https://en.wikipedia.org/wiki/Thin-film_deposition> ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-build> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

# Deposition Equipment
semicont-07-wfe-deposition-tools:DepositionEquipment a owl:Class ;
    rdfs:label "Deposition Equipment" ;
    rdfs:comment "Equipment for depositing thin films on wafers" ;
    rdfs:subClassOf semicont-shared:Equipment ;
    rdfs:isDefinedBy semicont-07-wfe-deposition-tools: ;
    dc:source "Public domain semiconductor equipment taxonomy" ;
    dc:rights "Fair use: generic deposition equipment category" ;
    prov:wasInformedBy "Industry-standard thin film deposition classifications" ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-build> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

