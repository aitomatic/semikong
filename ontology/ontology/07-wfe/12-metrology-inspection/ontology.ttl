# Module Metadata
semicont-07-wfe-metrology-inspection: a owl:Ontology ;
    rdfs:label "Metrology Inspection Ontology" ;
    rdfs:comment "Industry-general concepts for critical dimension and defect inspection equipment" ;
    owl:versionInfo "0.1.0" ;
    owl:imports <https://semicont.org/ontology/00-shared> ;
    dc:source "Public semiconductor engineering literature and industry-standard metrology classifications" ;
    dc:rights "Fair use: industry-general metrology concepts" ;
    prov:wasInformedBy "Model synthesis of public domain semiconductor metrology knowledge" ;
    prov:hadPrimarySource <https://en.wikipedia.org/wiki/Semiconductor_device_fabrication#Metrology> ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-build> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

# Metrology Equipment
