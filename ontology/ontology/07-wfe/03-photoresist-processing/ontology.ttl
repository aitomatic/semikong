# Module Metadata
semicont-07-wfe-photoresist-processing: a owl:Ontology ;
    rdfs:label "Photoresist Processing Ontology" ;
    rdfs:comment "Industry-general concepts for photoresist coating, baking, and developing equipment" ;
    owl:versionInfo "0.1.0" ;
    owl:imports <https://semicont.org/ontology/00-shared> ;
    dc:source "Public semiconductor lithography literature and industry-standard photoresist processing classifications" ;
    dc:rights "Fair use: industry-general photoresist processing concepts" ;
    prov:wasInformedBy "Model synthesis of public domain semiconductor lithography knowledge" ;
