# Etch Systems Ontology
# Shared spine for industry-general semiconductor etch systems.

@prefix semicont-07-wfe-etch-systems: <https://semicont.org/ontology/07-wfe/06-etch-systems#> .
@prefix semicont-shared: <https://semicont.org/ontology/00-shared#> .
@prefix semicont-standards: <https://semicont.org/ontology/01-standards-reference#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

semicont-07-wfe-etch-systems: a owl:Ontology ;
    rdfs:label "Etch Systems Ontology" ;
    rdfs:comment "Shared semantics for etch systems, settings, lifecycle, validation, and cross-branch interoperability." ;
    owl:versionInfo "0.1.0" ;
    owl:imports <https://semicont.org/ontology/00-shared> ;
    owl:imports <https://semicont.org/ontology/01-standards-reference> ;
    dc:source "Public process and standards references from SEMI, Fraunhofer ISIT, Oxford Instruments Plasma Technology, and Stanford Nanofabrication Facility." ;
    dc:rights "Fair use: paraphrased, industry-general process and equipment concepts; no proprietary recipes or company-internal implementation details." ;
    prov:hadPrimarySource <https://www.semi.org/en/products-services/standards> ;
    prov:hadPrimarySource <https://store-us.semi.org/products/e01000-semi-e10-specification-for-definition-and-measurement-of-equipment-reliability-availability-and-maintainability-ram-and-utilization> ;
    prov:hadPrimarySource <https://store-us.semi.org/products/s00200-semi-s2-environmental-health-and-safety-guideline-for-semiconductor-manufacturing-equipment> ;
    prov:hadPrimarySource <https://www.isit.fraunhofer.de/en/technology/micro-manufacturing-processes/processes-on-wafer-level/drie.html> ;
    prov:hadPrimarySource <https://plasma.oxinst.com/technology/icp-etching> ;
    prov:hadPrimarySource <https://snfguide.stanford.edu/guide/equipment/purpose/etching/wet-etching> ;
    prov:wasInformedBy "Cross-source synthesis of public etch process descriptions, standards context, and operational control patterns." ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-curation> ;
    prov:generatedAtTime "2026-03-11"^^xsd:date .

# Annotation properties
semicont-07-wfe-etch-systems:scopeNote a owl:AnnotationProperty ;
    rdfs:label "scope note" ;
    rdfs:isDefinedBy semicont-07-wfe-etch-systems: .

semicont-07-wfe-etch-systems:maturityLevel a owl:AnnotationProperty ;
    rdfs:label "maturity level" ;
    rdfs:isDefinedBy semicont-07-wfe-etch-systems: .

semicont-07-wfe-etch-systems:validated a owl:NamedIndividual ;
    rdfs:label "validated" ;
    rdfs:isDefinedBy semicont-07-wfe-etch-systems: .

semicont-07-wfe-etch-systems: semicont-07-wfe-etch-systems:scopeNote "Shared etch semantics across ALE, plasma, and wet branches. Branch-specific process/equipment details are defined in child modules."@en ;
    semicont-07-wfe-etch-systems:maturityLevel semicont-07-wfe-etch-systems:validated .

# Supported Use Cases Documentation
semicont-07-wfe-etch-systems:supportedUseCases a owl:AnnotationProperty ;
    rdfs:label "Supported Use Cases" ;
    rdfs:comment "Enumerates the practical applications and problems this ontology helps solve."@en ;
    rdfs:isDefinedBy semicont-07-wfe-etch-systems: .

semicont-07-wfe-etch-systems: semicont-07-wfe-etch-systems:supportedUseCases """
    1. Equipment Classification & Selection - Classify etch systems by type and select appropriate equipment for specific processes
    2. Process Recipe Design & Validation - Design etch recipes with parameters and validate against constraints
    3. Quality Specification Management - Define and track etch quality targets (sidewall angle, CD bias, uniformity)
    4. Process Stage Sequencing - Plan and monitor etch process flow through defined stages
    5. Equipment State & Lifecycle Management - Track equipment status and plan maintenance activities
    6. Capability-Based Equipment Matching - Match equipment capabilities to process requirements
    7. Cross-Branch Interoperability - Ensure consistency across ALE, plasma, and wet etch technologies
    8. Recipe Qualification & Comparison - Qualify new recipes against existing ones
    9. Engineering Unit Standardization - Ensure consistent units across equipment and processes
    10. Process Integration Safety - Verify processes meet integration constraints (thermal budget, charging damage)
"""@en .

