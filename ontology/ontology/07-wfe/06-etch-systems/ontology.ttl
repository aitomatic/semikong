# Shared object properties
semicont-07-wfe-etch-systems:usesEtchSystem a owl:ObjectProperty ;
    rdfs:domain semicont-07-wfe-etch-systems:EtchProcess ;
    rdfs:range semicont-07-wfe-etch-systems:EtchSystem .

semicont-07-wfe-etch-systems:hasEtchStage a owl:ObjectProperty ;
    rdfs:domain semicont-07-wfe-etch-systems:EtchProcess ;
    rdfs:range semicont-07-wfe-etch-systems:EtchStage .

semicont-07-wfe-etch-systems:hasCapability a owl:ObjectProperty ;
    rdfs:domain semicont-07-wfe-etch-systems:EtchSystem ;
    rdfs:range semicont-07-wfe-etch-systems:EtchCapability .

semicont-07-wfe-etch-systems:hasConstraint a owl:ObjectProperty ;
    rdfs:domain semicont-07-wfe-etch-systems:EtchProcess ;
    rdfs:range semicont-07-wfe-etch-systems:EtchConstraint .

semicont-07-wfe-etch-systems:hasSetpoint a owl:ObjectProperty ;
    rdfs:domain semicont-07-wfe-etch-systems:EtchRecipeSpec ;
    rdfs:range semicont-07-wfe-etch-systems:EtchParameter .

semicont-07-wfe-etch-systems:hasAcceptableRange a owl:ObjectProperty ;
    rdfs:domain semicont-07-wfe-etch-systems:EtchParameter ;
    rdfs:range semicont-07-wfe-etch-systems:ParameterRangeSpec .

semicont-07-wfe-etch-systems:hasProcessState a owl:ObjectProperty ;
    rdfs:domain semicont-07-wfe-etch-systems:EtchRecipeSpec ;
    rdfs:range semicont-07-wfe-etch-systems:RecipeQualificationState .

semicont-07-wfe-etch-systems:hasModuleState a owl:ObjectProperty ;
    rdfs:domain semicont-07-wfe-etch-systems:EtchSystem ;
    rdfs:range semicont-07-wfe-etch-systems:EtchModuleState .

semicont-07-wfe-etch-systems:hasChamberConfiguration a owl:ObjectProperty ;
    rdfs:domain semicont-07-wfe-etch-systems:EtchSystem ;
    rdfs:range semicont-07-wfe-etch-systems:EtchChamberConfiguration .

semicont-07-wfe-etch-systems:hasMeasure a owl:ObjectProperty ;
    rdfs:domain [ owl:unionOf ( semicont-07-wfe-etch-systems:EtchProcess semicont-07-wfe-etch-systems:EtchParameter semicont-07-wfe-etch-systems:EtchQualitySpec ) ] ;
    rdfs:range semicont-07-wfe-etch-systems:NumericMeasure .

semicont-07-wfe-etch-systems:hasUnit a owl:ObjectProperty ;
    rdfs:domain semicont-07-wfe-etch-systems:NumericMeasure ;
    rdfs:range semicont-07-wfe-etch-systems:EngineeringUnit .

semicont-07-wfe-etch-systems:allowedNextModuleState a owl:ObjectProperty ;
    rdfs:domain semicont-07-wfe-etch-systems:EtchModuleState ;
    rdfs:range semicont-07-wfe-etch-systems:EtchModuleState .

semicont-07-wfe-etch-systems:allowedNextRecipeState a owl:ObjectProperty ;
    rdfs:domain semicont-07-wfe-etch-systems:RecipeQualificationState ;
    rdfs:range semicont-07-wfe-etch-systems:RecipeQualificationState .

semicont-07-wfe-etch-systems:operatesEtchSystem a owl:ObjectProperty ;
    rdfs:domain semicont-07-wfe-etch-systems:EtchOperationalRole ;
    rdfs:range semicont-07-wfe-etch-systems:EtchSystem .

semicont-07-wfe-etch-systems:performsEtchProcess a owl:ObjectProperty ;
    rdfs:domain semicont-07-wfe-etch-systems:EtchOperationalRole ;
    rdfs:range semicont-07-wfe-etch-systems:EtchProcess .

semicont-07-wfe-etch-systems:ownsRecipeLifecycle a owl:ObjectProperty ;
    rdfs:domain semicont-07-wfe-etch-systems:EtchProcessEngineerRole ;
    rdfs:range semicont-07-wfe-etch-systems:EtchRecipeSpec .

# Shared datatype properties
semicont-07-wfe-etch-systems:hasNumericValue a owl:DatatypeProperty ;
    rdfs:domain semicont-07-wfe-etch-systems:NumericMeasure ;
    rdfs:range xsd:double .

semicont-07-wfe-etch-systems:hasEtchRate a owl:DatatypeProperty ;
    rdfs:domain semicont-07-wfe-etch-systems:EtchProcess ;
    rdfs:range xsd:double .

semicont-07-wfe-etch-systems:hasSelectivity a owl:DatatypeProperty ;
    rdfs:domain semicont-07-wfe-etch-systems:EtchProcess ;
    rdfs:range xsd:double .

semicont-07-wfe-etch-systems:hasUniformityPercent a owl:DatatypeProperty ;
    rdfs:domain semicont-07-wfe-etch-systems:EtchProcess ;
    rdfs:range xsd:double .

semicont-07-wfe-etch-systems:hasTargetEtchDepthNm a owl:DatatypeProperty ;
    rdfs:domain semicont-07-wfe-etch-systems:EtchRecipeSpec ;
    rdfs:range xsd:double .

semicont-07-wfe-etch-systems:hasCriticalDimensionBiasNm a owl:DatatypeProperty ;
    rdfs:domain semicont-07-wfe-etch-systems:EtchRecipeSpec ;
    rdfs:range xsd:double .

semicont-07-wfe-etch-systems:hasRangeMin a owl:DatatypeProperty ;
    rdfs:domain semicont-07-wfe-etch-systems:ParameterRangeSpec ;
    rdfs:range xsd:double .

semicont-07-wfe-etch-systems:hasRangeMax a owl:DatatypeProperty ;
    rdfs:domain semicont-07-wfe-etch-systems:ParameterRangeSpec ;
    rdfs:range xsd:double .

# Logical constraints
semicont-07-wfe-etch-systems:DryEtchSystem owl:disjointWith semicont-07-wfe-etch-systems:WetEtchSystem .
semicont-07-wfe-etch-systems:DryEtchProcess owl:disjointWith semicont-07-wfe-etch-systems:WetEtchProcess .
semicont-07-wfe-etch-systems:SingleChamberConfiguration owl:disjointWith semicont-07-wfe-etch-systems:ClusterToolConfiguration .
semicont-07-wfe-etch-systems:EtchOperatorRole owl:disjointWith semicont-07-wfe-etch-systems:EtchProcessEngineerRole .
semicont-07-wfe-etch-systems:EtchProcessEngineerRole owl:disjointWith semicont-07-wfe-etch-systems:EtchEquipmentEngineerRole .
semicont-07-wfe-etch-systems:EtchOperatorRole owl:disjointWith semicont-07-wfe-etch-systems:EtchEquipmentEngineerRole .

# State transitions
semicont-07-wfe-etch-systems:RecipeDevelopment semicont-07-wfe-etch-systems:allowedNextRecipeState semicont-07-wfe-etch-systems:RecipeQualified .
semicont-07-wfe-etch-systems:RecipeQualified semicont-07-wfe-etch-systems:allowedNextRecipeState semicont-07-wfe-etch-systems:RecipeReleased .
semicont-07-wfe-etch-systems:RecipeReleased semicont-07-wfe-etch-systems:allowedNextRecipeState semicont-07-wfe-etch-systems:RecipeRetired .
semicont-07-wfe-etch-systems:ModuleReady semicont-07-wfe-etch-systems:allowedNextModuleState semicont-07-wfe-etch-systems:ModuleRunning .
semicont-07-wfe-etch-systems:ModuleReady semicont-07-wfe-etch-systems:allowedNextModuleState semicont-07-wfe-etch-systems:ModuleMaintenance .
semicont-07-wfe-etch-systems:ModuleRunning semicont-07-wfe-etch-systems:allowedNextModuleState semicont-07-wfe-etch-systems:ModuleReady .
semicont-07-wfe-etch-systems:ModuleRunning semicont-07-wfe-etch-systems:allowedNextModuleState semicont-07-wfe-etch-systems:ModuleOutOfControl .
semicont-07-wfe-etch-systems:ModuleRunning semicont-07-wfe-etch-systems:allowedNextModuleState semicont-07-wfe-etch-systems:ModuleMaintenance .
semicont-07-wfe-etch-systems:ModuleOutOfControl semicont-07-wfe-etch-systems:allowedNextModuleState semicont-07-wfe-etch-systems:ModuleMaintenance .
semicont-07-wfe-etch-systems:ModuleOutOfControl semicont-07-wfe-etch-systems:allowedNextModuleState semicont-07-wfe-etch-systems:ModuleReady .
semicont-07-wfe-etch-systems:ModuleMaintenance semicont-07-wfe-etch-systems:allowedNextModuleState semicont-07-wfe-etch-systems:ModuleReady .

# Shared SHACL
semicont-07-wfe-etch-systems:EtchRecipeSpecShape a sh:NodeShape ;
    sh:targetClass semicont-07-wfe-etch-systems:EtchRecipeSpec ;
    sh:property [ sh:path semicont-07-wfe-etch-systems:hasSetpoint ; sh:minCount 1 ] ;
    sh:property [ sh:path semicont-07-wfe-etch-systems:hasProcessState ; sh:minCount 1 ; sh:maxCount 1 ] ;
    sh:property [ sh:path semicont-07-wfe-etch-systems:hasTargetEtchDepthNm ; sh:datatype xsd:double ; sh:minInclusive 0.0 ; sh:minCount 1 ] ;
    sh:property [ sh:path semicont-07-wfe-etch-systems:hasCriticalDimensionBiasNm ; sh:datatype xsd:double ] .

semicont-07-wfe-etch-systems:EtchProcessShape a sh:NodeShape ;
    sh:targetClass semicont-07-wfe-etch-systems:EtchProcess ;
    sh:property [ sh:path semicont-07-wfe-etch-systems:usesEtchSystem ; sh:minCount 1 ] ;
    sh:property [ sh:path semicont-07-wfe-etch-systems:hasEtchRate ; sh:datatype xsd:double ; sh:minInclusive 0.0 ] ;
    sh:property [ sh:path semicont-07-wfe-etch-systems:hasSelectivity ; sh:datatype xsd:double ; sh:minInclusive 0.0 ] ;
    sh:property [ sh:path semicont-07-wfe-etch-systems:hasUniformityPercent ; sh:datatype xsd:double ; sh:minInclusive 0.0 ; sh:maxInclusive 100.0 ] .

semicont-07-wfe-etch-systems:ParameterRangeSpecShape a sh:NodeShape ;
    sh:targetClass semicont-07-wfe-etch-systems:ParameterRangeSpec ;
    sh:property [ sh:path semicont-07-wfe-etch-systems:hasRangeMin ; sh:datatype xsd:double ; sh:minCount 1 ; sh:maxCount 1 ] ;
    sh:property [ sh:path semicont-07-wfe-etch-systems:hasRangeMax ; sh:datatype xsd:double ; sh:minCount 1 ; sh:maxCount 1 ] ;
    sh:sparql [
        sh:message "ParameterRangeSpec requires hasRangeMin <= hasRangeMax." ;
        sh:select """
            SELECT $this WHERE {
              $this semicont-07-wfe-etch-systems:hasRangeMin ?min ;
                    semicont-07-wfe-etch-systems:hasRangeMax ?max .
              FILTER (?min > ?max)
            }
        """ ;
    ] .

semicont-07-wfe-etch-systems:EtchSystemConfigurationShape a sh:NodeShape ;
    sh:targetClass semicont-07-wfe-etch-systems:EtchSystem ;
    sh:property [ sh:path semicont-07-wfe-etch-systems:hasChamberConfiguration ; sh:minCount 1 ; sh:maxCount 1 ] .

semicont-07-wfe-etch-systems:CriticalSetpointRangeShape a sh:NodeShape ;
    sh:targetClass semicont-07-wfe-etch-systems:EtchParameter ;
    sh:property [ sh:path semicont-07-wfe-etch-systems:hasAcceptableRange ; sh:minCount 1 ] .

# External alignment stubs
semicont-07-wfe-etch-systems:EtchModuleState skos:relatedMatch <https://store-us.semi.org/products/e01000-semi-e10-specification-for-definition-and-measurement-of-equipment-reliability-availability-and-maintainability-ram-and-utilization> .
semicont-07-wfe-etch-systems:EtchSystem skos:relatedMatch <https://store-us.semi.org/products/s00200-semi-s2-environmental-health-and-safety-guideline-for-semiconductor-manufacturing-equipment> .
semicont-07-wfe-etch-systems:EtchQualitySpec skos:relatedMatch <https://www.semi.org/en/products-services/standards> .
semicont-07-wfe-etch-systems:EtchProcess skos:relatedMatch <http://dbpedia.org/resource/Etching_(microfabrication)> .

# Limitations and Future Enhancements
semicont-07-wfe-etch-systems:limitationsNote a owl:AnnotationProperty ;
    rdfs:label "Limitations and Future Enhancements" ;
    rdfs:comment "Areas where the ontology coverage is limited and could be expanded."@en ;
    rdfs:isDefinedBy semicont-07-wfe-etch-systems: .

semicont-07-wfe-etch-systems: semicont-07-wfe-etch-systems:limitationsNote """
    Use Cases NOT YET WELL SUPPORTED:

    1. Specific Etch Chemistries - Detailed chemical reaction mechanisms and gas mixtures (placeholder modules exist)
    2. Advanced Endpoint Detection - Spectroscopic, interferometric, or other endpoint methods beyond basic timing
    3. Real-time Process Monitoring - Live data streams, sensor fusion, or adaptive control during etch
    4. Equipment-Specific Configurations - Vendor-specific chamber designs, hardware details, or proprietary features
    5. Yield and Defect Analysis - Statistical process control, defect classification, or yield prediction
    6. Multi-Physics Modeling - Coupled thermal, mechanical, or plasma physics simulations
    7. Environmental Impact - Chemical waste, energy consumption, or sustainability metrics
    8. Cost Analysis - Equipment ROI, cost per wafer, or economic optimization
    9. Machine Learning Integration - AI/ML models for process optimization or anomaly detection
    10. Supply Chain Integration - Parts availability, vendor management, or logistics coordination
"""@en .
