    prov:wasInformedBy "Isotropic liquid-phase removal behavior." ;
    rdfs:isDefinedBy semicont-07-wfe-etch-systems-wet: .

semicont-07-wfe-etch-systems:CrystallographicWetEtchProcess a owl:Class ;
