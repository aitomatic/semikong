semicont-07-wfe-etch-systems:ImmersionWetEtchSystem a owl:Class ;
    rdfs:label "Immersion Wet Etch System" ;
    rdfs:subClassOf semicont-07-wfe-etch-systems:BatchWetBenchEtchSystem ;
    dc:source "Public immersion wet etch references." ;
    prov:wasInformedBy "Immersion wet etch subtype." ;
    rdfs:isDefinedBy semicont-07-wfe-etch-systems-wet: .

# Process hierarchy
semicont-07-wfe-etch-systems:IsotropicWetEtchProcess a owl:Class ;
