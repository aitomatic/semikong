semicont-08-materials-chemicals-photoresists:Cyclohex_100 a owl:NamedIndividual , semicont-08-materials-chemicals-photoresists:Cyclohexanone ;
    rdfs:label "Cyclohexanone Solvent" ;
    rdfs:comment "Cyclohexanone for negative photoresist formulations" ;
    semicont-08-materials-chemicals:hasConcentrationPercent 100.0 ;
