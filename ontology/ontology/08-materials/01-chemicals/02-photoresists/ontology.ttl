    rdfs:label "PGMEA Solvent" ;
    rdfs:comment "Propylene glycol methyl ether acetate for positive photoresist" ;
    semicont-08-materials-chemicals:hasConcentrationPercent 100.0 ;
    semicont-08-materials-chemicals:hasPH semicont-08-materials-chemicals:NeutralPH ;
    semicont-08-materials-chemicals:hasCASNumber "108-65-6" ;
    semicont-08-materials-chemicals:hasStorageTemperature semicont-08-materials-chemicals:StandardRoomTemperature ;
    semicont-08-materials-chemicals-photoresists:hasViscositySimple 1.1 ;
    semicont-08-materials-chemicals-photoresists:hasEvaporationRate 0.19 ;
    prov:wasInformedBy "Industry standard photoresist solvent properties" ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-quality-improvement> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

