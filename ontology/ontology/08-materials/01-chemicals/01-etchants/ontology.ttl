# Specialty Etchants
semicont-08-materials-chemicals-etchants:HydrogenPeroxide a owl:Class ;
    rdfs:label "Hydrogen Peroxide" ;
    rdfs:comment "H2O2 for cleaning and as component of etching mixtures" ;
    rdfs:subClassOf semicont-08-materials-chemicals:ProcessChemical ;
    rdfs:isDefinedBy semicont-08-materials-chemicals-etchants: ;
    prov:wasInformedBy "SEMI C30 Hydrogen Peroxide Specification" ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-quality-improvement> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-08-materials-chemicals-etchants:BufferedOxideEtch a owl:Class ;
    rdfs:label "Buffered Oxide Etch" ;
    rdfs:comment "BOE - mixture of HF and NH4F for controlled oxide etching" ;
    rdfs:subClassOf semicont-08-materials-chemicals-etchants:SelectiveEtchant ;
    rdfs:isDefinedBy semicont-08-materials-chemicals-etchants: ;
    prov:wasInformedBy "Industry standard BOE formulation" ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-quality-improvement> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

# Etchant-specific Properties
semicont-08-materials-chemicals-etchants:hasEtchRate a owl:ObjectProperty ;
    rdfs:label "has etch rate" ;
    rdfs:comment "Rate of material removal as unitized value in nm/minute" ;
    rdfs:domain semicont-08-materials-chemicals:Etchant ;
    rdfs:range semicont-08-materials-chemicals:UnitizedValue ;
    rdfs:isDefinedBy semicont-08-materials-chemicals-etchants: ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-quality-improvement> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-08-materials-chemicals-etchants:hasEtchRateSimple a owl:DatatypeProperty ;
    rdfs:label "has etch rate simple" ;
    rdfs:comment "Etch rate in nm/minute for simple cases" ;
    rdfs:domain semicont-08-materials-chemicals:Etchant ;
    rdfs:range xsd:double ;
    rdfs:isDefinedBy semicont-08-materials-chemicals-etchants: ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-quality-improvement> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-08-materials-chemicals-etchants:hasSelectivityRatio a owl:DatatypeProperty ;
    rdfs:label "has selectivity ratio" ;
    rdfs:comment "Selectivity ratio between target material and mask/substrate" ;
    rdfs:domain semicont-08-materials-chemicals-etchants:SelectiveEtchant ;
    rdfs:range xsd:double ;
    rdfs:isDefinedBy semicont-08-materials-chemicals-etchants: ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-quality-improvement> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

# Improved Material Relationships (Object Properties)
semicont-08-materials-chemicals-etchants:etchesMaterial a owl:ObjectProperty ;
    rdfs:label "etches material" ;
    rdfs:comment "Material that this etchant can etch" ;
    rdfs:domain semicont-08-materials-chemicals:Etchant ;
    rdfs:range semicont-08-materials-chemicals-etchants:EtchableMaterial ;
    rdfs:isDefinedBy semicont-08-materials-chemicals-etchants: ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-quality-improvement> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-08-materials-chemicals-etchants:hasHighSelectivityTo a owl:ObjectProperty ;
    rdfs:label "has high selectivity to" ;
    rdfs:comment "Material to which this etchant has particularly high selectivity" ;
    rdfs:domain semicont-08-materials-chemicals-etchants:SelectiveEtchant ;
    rdfs:range semicont-08-materials-chemicals-etchants:EtchableMaterial ;
    rdfs:isDefinedBy semicont-08-materials-chemicals-etchants: ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-quality-improvement> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

# OWL Axioms
semicont-08-materials-chemicals-etchants:MineralAcid owl:disjointWith semicont-08-materials-chemicals-etchants:BufferedOxideEtch ;
    rdfs:comment "Pure acids and buffered mixtures are distinct etchant types" .

semicont-08-materials-chemicals-etchants:SelectiveEtchant rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty semicont-08-materials-chemicals-etchants:hasSelectivityRatio ;
    owl:minCardinality "1"^^xsd:nonNegativeInteger
] ;
    rdfs:comment "Selective etchants must have documented selectivity ratios" .

# SHACL Shapes for Etchants
semicont-08-materials-chemicals-etchants:EtchantShape a sh:NodeShape ;
    sh:targetClass semicont-08-materials-chemicals:Etchant ;
    sh:property [
        sh:path semicont-08-materials-chemicals-etchants:hasEtchRateSimple ;
        sh:datatype xsd:double ;
        sh:minInclusive 0.0 ;
        sh:message "Etch rate must be non-negative" ;
        sh:severity sh:Violation
    ] .

semicont-08-materials-chemicals-etchants:SelectiveEtchantShape a sh:NodeShape ;
    sh:targetClass semicont-08-materials-chemicals-etchants:SelectiveEtchant ;
    sh:property [
        sh:path semicont-08-materials-chemicals-etchants:hasSelectivityRatio ;
        sh:datatype xsd:double ;
        sh:minInclusive 1.0 ;
        sh:message "Selectivity ratio must be at least 1.0" ;
        sh:severity sh:Warning
    ] ;
    sh:property [
        sh:path semicont-08-materials-chemicals-etchants:hasHighSelectivityTo ;
        sh:minCount 1 ;
        sh:message "Selective etchant must specify at least one material with high selectivity" ;
        sh:severity sh:Info
    ] .

# Example Etchant Individuals with Unitized Values
semicont-08-materials-chemicals-etchants:HF_49 a owl:NamedIndividual , semicont-08-materials-chemicals-etchants:HydrofluoricAcid ;
    rdfs:label "49% Hydrofluoric Acid" ;
    rdfs:comment "Standard 49% HF for oxide etching with high selectivity" ;
    semicont-08-materials-chemicals:hasConcentrationPercent 49.0 ;
    semicont-08-materials-chemicals:hasPH [
        a semicont-08-materials-chemicals:UnitizedValue ;
        semicont-08-materials-chemicals:hasNumericValue 1.0 ;
        semicont-08-materials-chemicals:hasUnit "pH"
    ] ;
    semicont-08-materials-chemicals:hasCASNumber "7664-39-3" ;
    semicont-08-materials-chemicals:hasStorageTemperature semicont-08-materials-chemicals:StandardRoomTemperature ;
    semicont-08-materials-chemicals-etchants:hasEtchRateSimple 100.0 ;
    semicont-08-materials-chemicals-etchants:hasSelectivityRatio 50.0 ;
    semicont-08-materials-chemicals-etchants:etchesMaterial semicont-08-materials-chemicals-etchants:SiliconDioxide ;
    prov:wasInformedBy "Industry standard HF concentration for selective etching" ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-quality-improvement> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-08-materials-chemicals-etchants:BOE_7_1 a owl:NamedIndividual , semicont-08-materials-chemicals-etchants:BufferedOxideEtch ;
    rdfs:label "7:1 BOE" ;
    rdfs:comment "Buffered oxide etch with 7:1 NH4F:HF ratio for controlled etching" ;
    semicont-08-materials-chemicals:hasConcentrationPercent 100.0 ;
    semicont-08-materials-chemicals:hasPH [
        a semicont-08-materials-chemicals:UnitizedValue ;
        semicont-08-materials-chemicals:hasNumericValue 4.5 ;
        semicont-08-materials-chemicals:hasUnit "pH"
    ] ;
    semicont-08-materials-chemicals:hasStorageTemperature semicont-08-materials-chemicals:StandardRoomTemperature ;
    semicont-08-materials-chemicals-etchants:hasEtchRateSimple 15.0 ;
    semicont-08-materials-chemicals-etchants:hasSelectivityRatio 200.0 ;
    semicont-08-materials-chemicals-etchants:etchesMaterial semicont-08-materials-chemicals-etchants:SiliconDioxide ;
    semicont-08-materials-chemicals-etchants:hasHighSelectivityTo semicont-08-materials-chemicals-etchants:SiliconDioxide ;
    prov:wasInformedBy "Industry standard BOE formulation for controlled etch rate" ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-quality-improvement> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-08-materials-chemicals-etchants:H3PO4_85 a owl:NamedIndividual , semicont-08-materials-chemicals-etchants:PhosphoricAcid ;
    rdfs:label "85% Phosphoric Acid" ;
    rdfs:comment "Hot phosphoric acid for silicon nitride etching" ;
    semicont-08-materials-chemicals:hasConcentrationPercent 85.0 ;
    semicont-08-materials-chemicals:hasPH [
        a semicont-08-materials-chemicals:UnitizedValue ;
        semicont-08-materials-chemicals:hasNumericValue 1.0 ;
        semicont-08-materials-chemicals:hasUnit "pH"
    ] ;
    semicont-08-materials-chemicals:hasCASNumber "7664-38-2" ;
    semicont-08-materials-chemicals:hasStorageTemperature semicont-08-materials-chemicals:StandardRoomTemperature ;
    semicont-08-materials-chemicals-etchants:hasEtchRateSimple 5.0 ;
    semicont-08-materials-chemicals-etchants:hasSelectivityRatio 1000.0 ;
    semicont-08-materials-chemicals-etchants:etchesMaterial semicont-08-materials-chemicals-etchants:SiliconNitride ;
    semicont-08-materials-chemicals-etchants:hasHighSelectivityTo semicont-08-materials-chemicals-etchants:SiliconNitride ;
    prov:wasInformedBy "Industry standard for nitride etching with high selectivity" ;
