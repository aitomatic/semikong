# Etchants Ontology
# Etching chemicals for semiconductor manufacturing including acids and specialty etchants

@prefix semicont-08-materials-chemicals-etchants: <https://semicont.org/ontology/08-materials/01-chemicals/01-etchants#> .
@prefix semicont-08-materials-chemicals: <https://semicont.org/ontology/08-materials/01-chemicals#> .
@prefix semicont-08-materials: <https://semicont.org/ontology/08-materials#> .
@prefix semicont-shared: <https://semicont.org/ontology/00-shared#> .
@prefix semicont-standards: <https://semicont.org/ontology/01-standards-reference#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# Module Metadata
semicont-08-materials-chemicals-etchants: a owl:Ontology ;
    rdfs:label "Etchants Ontology" ;
    rdfs:comment "Etching chemicals for semiconductor manufacturing including acids and specialty etchants" ;
    owl:versionInfo "0.1.0" ;
    owl:imports <https://semicont.org/ontology/08-materials/01-chemicals> ;
    dc:source "SEMI C35 nitric acid specification and industry etching references" ;
    dc:rights "Fair use: publicly known etchant formulations" ;
    prov:wasInformedBy "SEMI C35 Nitric Acid Specification and semiconductor etching references" ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-quality-improvement> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date ;
    # Scope and maturity metadata
    semicont-08-materials-chemicals:scopeNote """
        SCOPE: Wet etching chemicals for semiconductor manufacturing
        - Includes: Mineral acids, specialty etchants, etch rates, selectivity properties
        - Excludes: Dry/plasma etching, proprietary etchant additives
        - Depth limit: Standard formulations (HF, BOE, SPM), no trade secrets
        """@en ;
    semicont-08-materials-chemicals:maturityLevel semicont-08-materials-chemicals:validated .

# Etchant Classes
semicont-08-materials-chemicals-etchants:MineralAcid a owl:Class ;
    dc:source "Etching in microfabrication reference (https://en.wikipedia.org/wiki/Etching_(microfabrication))" ;
    prov:wasInformedBy "Industry-standard wet/dry etchant and selectivity semantics." ;
    rdfs:label "Mineral Acid" ;
    rdfs:comment "Inorganic acid used in semiconductor processing" ;
    rdfs:subClassOf semicont-08-materials-chemicals:Acid ;
    rdfs:isDefinedBy semicont-08-materials-chemicals-etchants: ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-quality-improvement> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-08-materials-chemicals-etchants:WetEtchant a owl:Class ;
    rdfs:label "Wet Etchant" ;
    rdfs:comment "Liquid chemical used for wet etching processes" ;
    rdfs:subClassOf semicont-08-materials-chemicals:Etchant ;
    rdfs:isDefinedBy semicont-08-materials-chemicals-etchants: ;
    prov:wasInformedBy "Industry knowledge of wet etching processes" ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-quality-improvement> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-08-materials-chemicals-etchants:SelectiveEtchant a owl:Class ;
    rdfs:label "Selective Etchant" ;
    rdfs:comment "Etchant with high selectivity to specific materials" ;
    rdfs:subClassOf semicont-08-materials-chemicals-etchants:WetEtchant ;
    rdfs:isDefinedBy semicont-08-materials-chemicals-etchants: ;
    prov:wasInformedBy "Industry knowledge of selective etching" ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-quality-improvement> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

