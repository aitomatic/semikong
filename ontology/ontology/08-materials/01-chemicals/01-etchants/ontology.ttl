semicont-08-materials-chemicals-etchants:SPM a owl:NamedIndividual ;
    rdfs:label "Sulfuric-Peroxide Mixture" ;
    rdfs:comment "SPM - mixture of H2SO4 and H2O2 for photoresist stripping" ;
    a semicont-08-materials-chemicals:CleaningAgent, semicont-08-materials-chemicals-etchants:SulfuricAcid ;
    semicont-08-materials-chemicals:hasConcentrationPercent 96.0 ;
    semicont-08-materials-chemicals:hasPH [
        a semicont-08-materials-chemicals:UnitizedValue ;
        semicont-08-materials-chemicals:hasNumericValue 0.3 ;
        semicont-08-materials-chemicals:hasUnit "pH"
    ] ;
    semicont-08-materials-chemicals:hasStorageTemperature semicont-08-materials-chemicals:StandardRoomTemperature ;
    semicont-08-materials-chemicals-etchants:hasEtchRateSimple 200.0 ;
    semicont-08-materials-chemicals-etchants:etchesMaterial semicont-08-materials-chemicals-etchants:PhotoresistMaterial ;
    prov:wasInformedBy "Industry standard SPM formulation for resist stripping" ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-quality-improvement> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

