# Chemicals Foundation Ontology
# Core framework for semiconductor process chemicals with specifications and validation

@prefix semicont-08-materials-chemicals: <https://semicont.org/ontology/08-materials/01-chemicals#> .
@prefix semicont-shared: <https://semicont.org/ontology/00-shared#> .
@prefix semicont-standards: <https://semicont.org/ontology/01-standards-reference#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# Module Metadata
semicont-08-materials-chemicals: a owl:Ontology ;
    rdfs:label "Chemicals Foundation Ontology" ;
    rdfs:comment "Core framework for semiconductor process chemicals with specifications and validation" ;
    owl:versionInfo "0.1.0" ;
    owl:imports <https://semicont.org/ontology/00-shared> ;
    owl:imports <https://semicont.org/ontology/01-standards-reference> ;
    dc:source "SEMI standards C1, C30, C35 and public domain chemical references" ;
    dc:rights "Fair use: publicly known chemical specifications and industry standards" ;
    prov:wasInformedBy "SEMI chemical standards and semiconductor industry chemical references" ;
    prov:hadPrimarySource <https://www.semi.org/en/products-services/LiquidChemicalStandards> ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-quality-improvement> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date ;
    # Scope and maturity metadata
    rdfs:seeAlso <https://www.semi.org/en/products-services/LiquidChemicalStandards> ;
    rdfs:seeAlso semicont-standards:SEMI_C1 ;
    rdfs:seeAlso semicont-standards:SEMI_C30 ;
    rdfs:seeAlso semicont-standards:SEMI_C35 .

# Scope Boundary and Maturity
semicont-08-materials-chemicals:scopeNote a owl:AnnotationProperty ;
    rdfs:label "scope note" ;
    rdfs:comment "Notes about the scope and boundaries of this ontology" .

semicont-08-materials-chemicals:maturityLevel a owl:AnnotationProperty ;
    rdfs:label "maturity level" ;
    rdfs:comment "Indicates the maturity stage of the ontology module" .

semicont-08-materials-chemicals:validated a owl:NamedIndividual ;
    rdfs:label "validated" ;
    rdfs:comment "Ontology module has been validated with SHACL shapes and quality checks" .

# Module scope annotation
semicont-08-materials-chemicals: semicont-08-materials-chemicals:scopeNote """
    SCOPE: Semiconductor process chemicals foundation framework
    - Includes: Base chemical classes (Acid, Base, Solvent, etc.), specifications, properties
    - Excludes: Specific chemical formulations, proprietary blends, supplier information
    - Depth limit: Industry-general categories only, stops before company-specific products
    """@en ;
    semicont-08-materials-chemicals:maturityLevel semicont-08-materials-chemicals:validated .

# Core Chemical Classes
semicont-08-materials-chemicals:ProcessChemical a owl:Class ;
    rdfs:label "Process Chemical" ;
    rdfs:comment "Chemical substance used in semiconductor manufacturing processes" ;
    rdfs:subClassOf semicont-shared:Material ;
    rdfs:isDefinedBy semicont-08-materials-chemicals: ;
    prov:wasInformedBy "SEMI C1 Guide for Analysis of Liquid Chemicals" ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-quality-improvement> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-08-materials-chemicals:Acid a owl:Class ;
    rdfs:label "Acid" ;
    rdfs:comment "Acidic process chemical with pH < 7" ;
    rdfs:subClassOf semicont-08-materials-chemicals:ProcessChemical ;
    rdfs:isDefinedBy semicont-08-materials-chemicals: ;
    prov:wasInformedBy "SEMI C35 Nitric Acid Specification" ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-quality-improvement> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-08-materials-chemicals:Base a owl:Class ;
    rdfs:label "Base" ;
    rdfs:comment "Basic process chemical with pH > 7" ;
    rdfs:subClassOf semicont-08-materials-chemicals:ProcessChemical ;
    rdfs:isDefinedBy semicont-08-materials-chemicals: ;
    prov:wasInformedBy "SEMI standards for basic chemicals" ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-quality-improvement> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-08-materials-chemicals:Solvent a owl:Class ;
    rdfs:label "Solvent" ;
    rdfs:comment "Organic solvent used for cleaning or as photoresist carrier" ;
    rdfs:subClassOf semicont-08-materials-chemicals:ProcessChemical ;
    rdfs:isDefinedBy semicont-08-materials-chemicals: ;
