semicont-08-materials-chemicals:hasSEMIStandardNumber a owl:DatatypeProperty ;
    rdfs:label "has SEMI standard number" ;
    rdfs:comment "SEMI standard specification number" ;
    rdfs:domain semicont-08-materials-chemicals:SEMIGradeSpec ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy semicont-08-materials-chemicals: ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-quality-improvement> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

# Disjointness Axioms
semicont-08-materials-chemicals:Acid owl:disjointWith semicont-08-materials-chemicals:Base ;
    rdfs:comment "Acids and bases are chemically incompatible" .

semicont-08-materials-chemicals:Acid owl:disjointWith semicont-08-materials-chemicals:Solvent ;
    rdfs:comment "Acids and solvents have different chemical properties" .

semicont-08-materials-chemicals:Base owl:disjointWith semicont-08-materials-chemicals:Solvent ;
    rdfs:comment "Bases and solvents have different chemical properties" .

# Class Restrictions
semicont-08-materials-chemicals:ProcessChemical rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty semicont-08-materials-chemicals:hasCASNumber ;
    owl:cardinality "1"^^xsd:nonNegativeInteger
] ;
    rdfs:comment "Every process chemical must have exactly one CAS number" .

semicont-08-materials-chemicals:ProcessChemical rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty semicont-08-materials-chemicals:hasPuritySpec ;
    owl:minCardinality "1"^^xsd:nonNegativeInteger
] ;
    rdfs:comment "Every process chemical must have at least one purity specification" .

semicont-08-materials-chemicals:SEMIGradeSpec rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty semicont-08-materials-chemicals:hasSEMIStandardNumber ;
    owl:cardinality "1"^^xsd:nonNegativeInteger
] ;
    rdfs:comment "Every SEMI grade spec must have exactly one standard number" .

# SHACL Shapes for Validation
semicont-08-materials-chemicals:ProcessChemicalShape a sh:NodeShape ;
    sh:targetClass semicont-08-materials-chemicals:ProcessChemical ;
    sh:property [
        sh:path semicont-08-materials-chemicals:hasCASNumber ;
        sh:datatype xsd:string ;
        sh:pattern "^[0-9]{2,7}-[0-9]{2}-[0-9]$" ;
        sh:message "CAS number must be in format NNNNNNN-NN-N" ;
        sh:severity sh:Violation
    ] ;
    sh:property [
        sh:path semicont-08-materials-chemicals:hasConcentrationPercent ;
        sh:datatype xsd:double ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 100.0 ;
        sh:message "Concentration must be between 0 and 100 percent" ;
        sh:severity sh:Violation
    ] .

semicont-08-materials-chemicals:UnitizedValueShape a sh:NodeShape ;
    sh:targetClass semicont-08-materials-chemicals:UnitizedValue ;
    sh:property [
        sh:path semicont-08-materials-chemicals:hasNumericValue ;
        sh:datatype xsd:double ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Unitized value must have exactly one numeric value" ;
        sh:severity sh:Violation
    ] ;
    sh:property [
        sh:path semicont-08-materials-chemicals:hasUnit ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Unitized value must have exactly one unit" ;
        sh:severity sh:Violation
    ] .

semicont-08-materials-chemicals:PuritySpecShape a sh:NodeShape ;
    sh:targetClass semicont-08-materials-chemicals:PuritySpec ;
    sh:property [
        sh:path semicont-08-materials-chemicals:hasSEMIStandardNumber ;
        sh:datatype xsd:string ;
        sh:pattern "^SEMI\s+[A-Z][0-9]+-[0-9]{4}$" ;
        sh:message "SEMI standard must be in format 'SEMI CXX-YYYY'" ;
        sh:severity sh:Violation
    ] .

