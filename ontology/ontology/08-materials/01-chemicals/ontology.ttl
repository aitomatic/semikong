# Unitized Value Pattern for Quantities
semicont-08-materials-chemicals:UnitizedValue a owl:Class ;
    dc:source "SEMI liquid chemical standards index (https://www.semi.org/en/products-services/LiquidChemicalStandards)" ;
    prov:wasInformedBy "SEMI-aligned process chemical and specification semantics." ;
    rdfs:label "Unitized Value" ;
    rdfs:comment "A value with associated unit of measurement" ;
    rdfs:isDefinedBy semicont-08-materials-chemicals: ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-quality-improvement> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-08-materials-chemicals:hasNumericValue a owl:DatatypeProperty ;
    rdfs:label "has numeric value" ;
    rdfs:comment "The numeric value of a unitized quantity" ;
    rdfs:domain semicont-08-materials-chemicals:UnitizedValue ;
    rdfs:range xsd:double ;
    rdfs:isDefinedBy semicont-08-materials-chemicals: ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-quality-improvement> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-08-materials-chemicals:hasUnit a owl:DatatypeProperty ;
    rdfs:label "has unit" ;
    rdfs:comment "The unit of measurement for a unitized value" ;
    rdfs:domain semicont-08-materials-chemicals:UnitizedValue ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy semicont-08-materials-chemicals: ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-quality-improvement> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

