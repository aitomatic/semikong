    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-quality-improvement> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-08-materials-chemicals:CleaningAgent a owl:Class ;
    rdfs:label "Cleaning Agent" ;
    rdfs:comment "Chemical used for wafer cleaning processes" ;
    rdfs:subClassOf semicont-08-materials-chemicals:ProcessChemical ;
    rdfs:isDefinedBy semicont-08-materials-chemicals: ;
