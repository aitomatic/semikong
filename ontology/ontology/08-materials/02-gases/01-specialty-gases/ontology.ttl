# Specialty Process Gases Ontology
# High-purity gases for etching, doping, and inert applications

@prefix semicont-08-materials-02-gases-01-specialty-gases: <https://semicont.org/ontology/08-materials/02-gases/01-specialty-gases/#> .
@prefix semicont-08-materials-02-gases: <https://semicont.org/ontology/08-materials/02-gases/#> .
@prefix semicont-08-materials: <https://semicont.org/ontology/08-materials/#> .
@prefix semicont-08-materials-gases: <https://semicont.org/ontology/08-materials/02-gases#> .
@prefix semicont-shared: <https://semicont.org/ontology/00-shared#> .
@prefix semicont-standards: <https://semicont.org/ontology/01-standards-reference#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix unit: <http://qudt.org/vocab/unit/> .

semicont-08-materials-02-gases-01-specialty-gases: a owl:Ontology ;
    rdfs:label "Specialty Process Gases Ontology" ;
    rdfs:comment "High-purity gases for etching, doping, and inert applications" ;
    owl:versionInfo "0.1.0" ;
    owl:imports <https://semicont.org/ontology/08-materials/02-gases> ;
    owl:imports <https://semicont.org/ontology/00-shared> ;
    dc:source "SEMI C3, C10, C48 specialty gas standards and industry etch/dopant references" ;
    dc:rights "Fair use: publicly known gas specifications and process applications" ;
    prov:wasInformedBy "SEMI C3 specialty gas specifications and industry process knowledge" ;
    prov:hadPrimarySource <https://www.semi.org/en/products-services/standards/materials> ;
    prov:wasGeneratedBy "semicont-materials-curation" ;
    prov:generatedAtTime "2026-03-10"^^xsd:date ;
    # Scope and maturity metadata
    semicont-08-materials:scopeNote """
        SCOPE: Specialty process gases for semiconductor manufacturing
        - Includes: Etch gases, dopant gases, inert gases with SEMI specifications
        - Excludes: Bulk industrial gases, reactive gases without SEMI specs
        - Depth limit: SEMI C3/C10/C48 specifications, no proprietary mixtures
        """@en ;
    semicont-08-materials:maturityLevel semicont-08-materials:curated .

# Etch Gas Subclasses
semicont-08-materials-02-gases-01-specialty-gases:FluorinatedEtchGas a owl:Class ;
    rdfs:label "Fluorinated Etch Gas" ;
    rdfs:comment "Fluorine-containing gas for plasma etching" ;
    rdfs:subClassOf semicont-08-materials-gases:EtchGas ;
    rdfs:isDefinedBy semicont-08-materials-02-gases-01-specialty-gases: ;
    prov:wasInformedBy "Industry knowledge of fluorine-based plasma etching" ;
    prov:wasGeneratedBy "semicont-materials-curation" ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-08-materials-02-gases-01-specialty-gases:ChlorinatedEtchGas a owl:Class ;
    rdfs:label "Chlorinated Etch Gas" ;
    rdfs:comment "Chlorine-containing gas for plasma etching" ;
    rdfs:subClassOf semicont-08-materials-gases:EtchGas ;
    rdfs:isDefinedBy semicont-08-materials-02-gases-01-specialty-gases: ;
    prov:wasInformedBy "Industry knowledge of chlorine-based plasma etching" ;
    prov:wasGeneratedBy "semicont-materials-curation" ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

# Specific Etch Gases
