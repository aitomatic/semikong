# Properties
semicont-08-materials-02-gases-01-specialty-gases:hasSelectivityRatio a owl:ObjectProperty ;
    rdfs:label "has selectivity ratio" ;
    rdfs:comment "Etch selectivity ratio between materials" ;
    rdfs:domain semicont-08-materials-gases:EtchGas ;
    rdfs:range semicont-shared:UnitizedValue ;
    rdfs:isDefinedBy semicont-08-materials-02-gases-01-specialty-gases: ;
    prov:wasGeneratedBy "semicont-materials-curation" ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-08-materials-02-gases-01-specialty-gases:isDopantType a owl:DatatypeProperty ;
    rdfs:label "is dopant type" ;
    rdfs:comment "n-type or p-type dopant classification" ;
    rdfs:domain semicont-08-materials-gases:DopantGas ;
