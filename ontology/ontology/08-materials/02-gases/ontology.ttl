# Specialty Gases Foundation Ontology
# High-purity gases and precursors for semiconductor manufacturing

@prefix semicont-08-materials-gases: <https://semicont.org/ontology/08-materials/02-gases#> .
@prefix semicont-08-materials: <https://semicont.org/ontology/08-materials#> .
@prefix semicont-shared: <https://semicont.org/ontology/00-shared#> .
@prefix semicont-standards: <https://semicont.org/ontology/01-standards-reference#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# Module Metadata
semicont-08-materials-gases: a owl:Ontology ;
    rdfs:label "Specialty Gases Foundation Ontology" ;
    rdfs:comment "High-purity gases and precursors for semiconductor manufacturing" ;
    owl:versionInfo "0.1.0" ;
    owl:imports <https://semicont.org/ontology/08-materials> ;
    dc:source "SEMI C3, C10, C48 specialty gas specifications and industry references" ;
    dc:rights "Fair use: publicly known gas specifications and industry standards" ;
    prov:wasInformedBy "SEMI C3 specialty gas standards and semiconductor industry references" ;
    prov:hadPrimarySource <https://www.semi.org/en/products-services/standards/materials> ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-materials-curation> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date ;
    # Scope and maturity metadata
    semicont-08-materials:scopeNote """
        SCOPE: Specialty gases and precursors for semiconductor manufacturing
        - Includes: Precursor gases, dopants, etchants, inert gases with SEMI specifications
        - Excludes: Bulk industrial gases, proprietary gas mixtures, supplier-specific grades
        - Depth limit: SEMI C3 series specifications, no trade secret formulations
        """@en ;
    semicont-08-materials:maturityLevel semicont-08-materials:curated .

# Core Gas Classes
semicont-08-materials-gases:SpecialtyGas a owl:Class ;
    rdfs:label "Specialty Gas" ;
    rdfs:comment "High-purity gas used in semiconductor processes" ;
    rdfs:subClassOf semicont-08-materials:SpecialtyGas ;
    rdfs:isDefinedBy semicont-08-materials-gases: ;
    prov:wasInformedBy "SEMI C3 specialty gas specifications" ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-materials-curation> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-08-materials-gases:PrecursorGas a owl:Class ;
    rdfs:label "Precursor Gas" ;
    rdfs:comment "Gas used as chemical precursor for deposition processes" ;
    rdfs:subClassOf semicont-08-materials-gases:SpecialtyGas ;
    rdfs:isDefinedBy semicont-08-materials-gases: ;
    prov:wasInformedBy "Industry knowledge of CVD/ALD precursors" ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-materials-curation> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-08-materials-gases:DopantGas a owl:Class ;
    rdfs:label "Dopant Gas" ;
    rdfs:comment "Gas used for semiconductor doping processes" ;
    rdfs:subClassOf semicont-08-materials-gases:SpecialtyGas ;
    rdfs:isDefinedBy semicont-08-materials-gases: ;
    prov:wasInformedBy "Industry knowledge of semiconductor doping" ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-materials-curation> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-08-materials-gases:EtchGas a owl:Class ;
    rdfs:label "Etch Gas" ;
    rdfs:comment "Gas used for plasma or chemical etching processes" ;
    rdfs:subClassOf semicont-08-materials-gases:SpecialtyGas ;
    rdfs:isDefinedBy semicont-08-materials-gases: ;
    prov:wasInformedBy "Industry knowledge of plasma etching" ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-materials-curation> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-08-materials-gases:InertGas a owl:Class ;
    rdfs:label "Inert Gas" ;
    rdfs:comment "Chemically inert gas used for purge and carrier applications" ;
    rdfs:subClassOf semicont-08-materials-gases:SpecialtyGas ;
    rdfs:isDefinedBy semicont-08-materials-gases: ;
    prov:wasInformedBy "Industry knowledge of inert gas applications" ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-materials-curation> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

