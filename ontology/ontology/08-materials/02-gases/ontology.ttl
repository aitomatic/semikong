# Gas-specific Properties
semicont-08-materials-gases:hasPurityLevel a owl:DatatypeProperty ;
    rdfs:label "has purity level" ;
    rdfs:comment "Gas purity as percentage (e.g., 99.999 for 5N)" ;
    rdfs:domain semicont-08-materials-gases:SpecialtyGas ;
    rdfs:range xsd:double ;
    rdfs:isDefinedBy semicont-08-materials-gases: ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-materials-curation> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-08-materials-gases:hasNinesNotation a owl:DatatypeProperty ;
    rdfs:label "has nines notation" ;
    rdfs:comment "Purity in nines notation (e.g., "5N5" for 99.9995%)" ;
    rdfs:domain semicont-08-materials-gases:SpecialtyGas ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy semicont-08-materials-gases: ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-materials-curation> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-08-materials-gases:hasCASNumber a owl:DatatypeProperty ;
    rdfs:label "has CAS number" ;
    rdfs:comment "Chemical Abstracts Service registry number" ;
    rdfs:domain semicont-08-materials-gases:SpecialtyGas ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy semicont-08-materials-gases: ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-materials-curation> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

# OWL Axioms
semicont-08-materials-gases:PrecursorGas owl:disjointWith semicont-08-materials-gases:DopantGas ;
    rdfs:comment "Precursors and dopants serve different functions in processing" .

semicont-08-materials-gases:DopantGas owl:disjointWith semicont-08-materials-gases:InertGas ;
    rdfs:comment "Dopants and inert gases have different chemical behaviors" .

semicont-08-materials-gases:PrecursorGas owl:disjointWith semicont-08-materials-gases:InertGas ;
    rdfs:comment "Precursors and inert gases have different reactivities" .

# Class Restrictions
semicont-08-materials-gases:SpecialtyGas rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty semicont-08-materials-gases:hasCASNumber ;
    owl:cardinality "1"^^xsd:nonNegativeInteger
] ;
    rdfs:comment "Every specialty gas must have exactly one CAS number" .

# SHACL Shapes for Validation
semicont-08-materials-gases:SpecialtyGasShape a sh:NodeShape ;
    sh:targetClass semicont-08-materials-gases:SpecialtyGas ;
    sh:property [
        sh:path semicont-08-materials-gases:hasCASNumber ;
        sh:datatype xsd:string ;
        sh:pattern "^[0-9]{2,7}-[0-9]{2}-[0-9]$" ;
        sh:message "CAS number must be in format NNNNNNN-NN-N" ;
        sh:severity sh:Violation
    ] ;
    sh:property [
        sh:path semicont-08-materials-gases:hasPurityLevel ;
        sh:datatype xsd:double ;
        sh:minInclusive 99.0 ;
        sh:maxInclusive 100.0 ;
        sh:message "Purity must be between 99% and 100%" ;
        sh:severity sh:Violation
    ] .

semicont-08-materials-gases:PrecursorGasShape a sh:NodeShape ;
    sh:targetClass semicont-08-materials-gases:PrecursorGas ;
    sh:property [
        sh:path semicont-08-materials-gases:hasPurityLevel ;
        sh:datatype xsd:double ;
        sh:minInclusive 99.99 ;
        sh:message "Precursor gases typically require 4N (99.99%) or higher purity" ;
        sh:severity sh:Warning
    ] .

# Example Gas Individuals
semicont-08-materials-gases:SiH4_5N a owl:NamedIndividual , semicont-08-materials-gases:Silane ;
    rdfs:label "5N Silane" ;
    rdfs:comment "99.999% pure silane for semiconductor applications" ;
    semicont-08-materials-gases:hasPurityLevel 99.999 ;
    semicont-08-materials-gases:hasNinesNotation "5N" ;
    semicont-08-materials-gases:hasCASNumber "7803-62-5" ;
    prov:wasInformedBy "SEMI C3.55-0200 Standard for Silane (SiH4), Bulk" ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-materials-curation> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-08-materials-gases:PH3_6N5 a owl:NamedIndividual , semicont-08-materials-gases:Phosphine ;
    rdfs:label "6N5 Phosphine" ;
    rdfs:comment "99.9995% pure phosphine for doping applications" ;
    semicont-08-materials-gases:hasPurityLevel 99.9995 ;
    semicont-08-materials-gases:hasNinesNotation "6N5" ;
    semicont-08-materials-gases:hasCASNumber "7803-51-2" ;
    prov:wasInformedBy "SEMI C3 dopant gas specifications" ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-materials-curation> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

semicont-08-materials-gases:N2_6N a owl:NamedIndividual , semicont-08-materials-gases:Nitrogen ;
    rdfs:label "6N Nitrogen" ;
    rdfs:comment "99.9999% pure nitrogen for UHP applications" ;
    semicont-08-materials-gases:hasPurityLevel 99.9999 ;
    semicont-08-materials-gases:hasNinesNotation "6N" ;
    semicont-08-materials-gases:hasCASNumber "7727-37-9" ;
    prov:wasInformedBy "SEMI C3.25 and SEMI F20 UHP nitrogen standards" ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-materials-curation> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

# External Mappings
semicont-08-materials-gases:Silane rdfs:seeAlso semicont-standards:SEMI_C3 ;
    rdfs:seeAlso <https://pubchem.ncbi.nlm.nih.gov/compound/23953> .

semicont-08-materials-gases:Phosphine rdfs:seeAlso semicont-standards:SEMI_C3 ;
