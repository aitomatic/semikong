@prefix dc: <http://purl.org/dc/elements/1.1/> .

# Module Metadata
semicont-shared: a owl:Ontology ;
    rdfs:label "Semicont Shared Layer Foundation" ;
    rdfs:comment "Cross-cutting concepts and shared resources across all semiconductor industry layers" ;
    owl:versionInfo "0.1.0" ;
    dc:source "W3C standard vocabularies and industry-general semiconductor concepts" ;
    dc:rights "Fair use: foundational ontology concepts" ;
    prov:wasInformedBy "Model synthesis of W3C standards and industry-general semantics" ;
    prov:hadPrimarySource <https://www.w3.org/2001/sw/wiki/OWL> ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-build> ;
    prov:generatedAtTime "2026-03-10"^^xsd:date .

