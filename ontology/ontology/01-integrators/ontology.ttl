# System Integrators Layer Foundation Ontology
# Concepts for system integration companies

@prefix semicont-integrators: <https://semicont.org/ontology/01-integrators#> .
@prefix semicont-core: <https://semicont.org/ontology/00-shared#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .

# Module Metadata
semicont-integrators: a owl:Ontology ;
    rdfs:label "System Integrators Layer Foundation" ;
    rdfs:comment "Concepts for system integration companies like Apple, Google, Tesla" ;
    owl:versionInfo "0.1.0" ;
    owl:imports <https://semicont.org/ontology/00-shared> ;
            dc:source "Public domain knowledge of system integrators" ;
    dc:rights "Fair use: general integrator concepts" ;
    dc:source "Public domain knowledge of system integrators" ;
    dc:rights "Fair use: general integrator concepts" ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-build> ;
    prov:generatedAtTime "2026-03-09"^^xsd:date .

# System Integration Concepts
semicont-integrators:SystemIntegrator a owl:Class ;
    rdfs:label "System Integrator" ;
    rdfs:comment "Companies that integrate semiconductor components into complete systems" ;
    rdfs:subClassOf semicont-core:Organization ;
    rdfs:isDefinedBy semicont-integrators: ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-build> ;
    prov:generatedAtTime "2026-03-09"^^xsd:date .

semicont-integrators:EndUseApplication a owl:Class ;
    rdfs:label "End Use Application" ;
    rdfs:comment "Application domains for integrated systems" ;
    rdfs:isDefinedBy semicont-integrators: ;
    prov:wasGeneratedBy <https://semicont.org/prov/activity/semicont-ontology-build> ;
    prov:generatedAtTime "2026-03-09"^^xsd:date .
